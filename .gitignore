# Frontend (Next.js app)
website/node_modules/
website/.next/
website/out/
website/build/
website/.vercel
website/*.tsbuildinfo
website/next-env.d.ts

# Env / secrets — NEVER commit credentials or tokens
.env*
!.env.example
!.env.*.example
# Secret patterns (defense-in-depth)
**/*token*
**/*secret*
**/*credential*
**/.vercel
**/auth.json

# Vercel tokens must live in env only, never in repo
.vscode/
.vscode/sftp.json

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Logs
*.log
npm-debug.log*

# Python (archived prototype)
archive/**/__pycache__/
archive/**/*.pyc
archive/**/.venv/
