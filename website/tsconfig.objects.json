{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["es2020", "dom"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": "src",
    "outDir": ".constitution-build",
    "types": [],
    "noEmit": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/constitution/**/*.ts"]
}
