# Development environment — copy to .env for local work.
ENVIRONMENT=development
SECRET_KEY=dev-only-not-a-real-secret
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=DEBUG
LOG_FORMAT=text
DATABASE_URL=sqlite:///./happy_place.db

GOOGLE_PROJECT_ID=dev-project-id
GOOGLE_CLIENT_ID=dev.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=dev-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback
GOOGLE_WORKSPACE_EMAIL=dev@your-dev-workspace.com
GOOGLE_DRIVE_ROOT_FOLDER=dev-root-folder-id
GOOGLE_CALENDAR_ID=primary

MAIL_MODE=dev
GOOGLE_USE_MOCK=true

OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/drive https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/contacts.readonly
