# Staging environment — set these as real environment variables on the host.
ENVIRONMENT=staging
SECRET_KEY=replace-with-staging-secret
FRONTEND_URL=https://staging.happyplace.example
LOG_LEVEL=INFO
LOG_FORMAT=json
DATABASE_URL=postgresql+psycopg://USER:PASS@HOST:5432/happyplace_staging

GOOGLE_PROJECT_ID=staging-project-id
GOOGLE_CLIENT_ID=staging.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=staging-secret
GOOGLE_REDIRECT_URI=https://staging-api.happyplace.example/api/auth/callback
GOOGLE_WORKSPACE_EMAIL=staging@client-workspace.com
GOOGLE_DRIVE_ROOT_FOLDER=staging-root-folder-id
GOOGLE_CALENDAR_ID=primary

MAIL_MODE=live
# Real Google calls once staging credentials are authorized.
GOOGLE_USE_MOCK=false

OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/drive https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/contacts.readonly
