# Production environment — set these as REAL environment variables (never commit).
ENVIRONMENT=production
SECRET_KEY=replace-with-a-long-secure-random-string
FRONTEND_URL=https://happyplace.example
LOG_LEVEL=INFO
LOG_FORMAT=json
DATABASE_URL=postgresql+psycopg://USER:PASS@HOST:5432/happyplace

GOOGLE_PROJECT_ID=prod-project-id
GOOGLE_CLIENT_ID=prod.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=prod-secret
GOOGLE_REDIRECT_URI=https://api.happyplace.example/api/auth/callback
GOOGLE_WORKSPACE_EMAIL=admin@client-workspace.com
GOOGLE_DRIVE_ROOT_FOLDER=prod-root-folder-id
GOOGLE_CALENDAR_ID=primary

MAIL_MODE=live
GOOGLE_USE_MOCK=false

OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/drive https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/contacts.readonly
