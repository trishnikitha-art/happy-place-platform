# =====================================================================
# Happy Place Backend — Environment Configuration
# =====================================================================
# Copy this file to `.env` and fill in real development values.
# NEVER commit real secrets. NEVER hardcode client-specific data.
# Every value here is configuration — nothing is baked into the code.
#
# In staging/production, set these as real environment variables
# (CI secrets, container env, etc.) instead of a committed .env file.
# =====================================================================

# ---- Environment ----
# One of: development | staging | production
ENVIRONMENT=development

# ---- Application ----
APP_NAME=Happy Place Backend
SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=INFO
# json | text  (json is preferred for future monitoring/ingest)
LOG_FORMAT=json

# ---- Database ----
# SQLite for local dev. Swap to PostgreSQL by changing this ONE variable.
#   postgresql+psycopg://USER:PASS@HOST:5432/happyplace
DATABASE_URL=sqlite:///./happy_place.db

# ---- Google Workspace (DEVELOPMENT credentials) ----
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match an authorized redirect URI in the Google Cloud console.
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback
# The development Workspace / Google account the app acts as.
GOOGLE_WORKSPACE_EMAIL=
# ID of the Drive folder that holds all customer project folders.
GOOGLE_DRIVE_ROOT_FOLDER=
# Calendar the app writes appointments to ("primary" or a specific calendar id).
GOOGLE_CALENDAR_ID=primary

# ---- Mail behavior ----
# dev  -> emails are rendered and logged, NOT sent (safe for local dev)
# live -> emails are sent through the Gmail API
MAIL_MODE=dev

# ---- Google integration mode ----
# true  -> use in-memory mocks (no real Google calls; great for tests/offline)
# false -> call the real Google APIs (requires valid OAuth credentials)
GOOGLE_USE_MOCK=true

# ---- OAuth scopes (space separated) ----
OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/drive https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/contacts.readonly
